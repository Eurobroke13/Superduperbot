{
  "name": "superduperbot",
  "version": "1.0.0",
  "type": "module",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "import:state": "node import-state.js",
    "task:fast-scan": "node task-runner.js fast-scan",
    "task:run-bot": "node task-runner.js run-bot",
    "task:daily-report": "node task-runner.js daily-report",
    "task:weekly-review": "node task-runner.js weekly-review",
    "task:premarket": "node task-runner.js premarket",
    "task:reevaluate": "node task-runner.js reevaluate",
    "test": "node --test tests/*.test.js",
    "test:watch": "node --test --watch tests/*.test.js",
    "railway:run-bot": "npm run task:run-bot",
    "backtest": "node backtest.js",
    "backtest:seed": "node backtest.js --seed",
    "backtest:seed-safe": "node backtest.js --seed-safe",
    "backtest:seed-safe:replace-regimes": "node backtest.js --seed-safe --force-replace-regimes",
    "backtest:dry": "node backtest.js --no-db",
    "backtest:3m": "node backtest.js --months 3",
    "backtest:seed:3m": "node backtest.js --months 3 --seed",
    "backtest:seed-safe:3m": "node backtest.js --months 3 --seed-safe",
    "backtest:seed-safe:replace-regimes:3m": "node backtest.js --months 3 --seed-safe --force-replace-regimes"
  },
  "dependencies": {
    "express": "^4.18.2",
    "pg": "^8.11.5",
    "dotenv": "^16.4.5"
  }
}
